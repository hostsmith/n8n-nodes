{
	"name": "@hostsmith/n8n-nodes-hostsmith",
	"version": "0.0.0",
	"description": "n8n community node to manage Hostsmith sites, domains, and account",
	"license": "MIT",
	"homepage": "https://hostsmith.net",
	"keywords": [
		"n8n-community-node-package",
		"hostsmith",
		"hosting",
		"deploy",
		"publish",
		"site",
		"artifact",
		"pdf",
		"host"
	],
	"author": {
		"name": "Hostsmith",
		"email": "support@ops42.org"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hostsmith/n8n-nodes.git"
	},
	"bugs": {
		"url": "https://github.com/hostsmith/n8n-nodes/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prepublishOnly": "npm run build"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HostsmithOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Hostsmith/Hostsmith.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
